<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.LinkedAccountsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_auth`.`linked_accounts`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('user_id')">`user_id`,</if>
            <if test="_parameter.containsKey('provider')">`provider`,</if>
            <if test="_parameter.containsKey('provider_user_id')">`provider_user_id`,</if>
            <if test="_parameter.containsKey('provider_email')">`provider_email`,</if>
            <if test="_parameter.containsKey('provider_nickname')">`provider_nickname`,</if>
            <if test="_parameter.containsKey('provider_avatar_url')">`provider_avatar_url`,</if>
            <if test="_parameter.containsKey('linked_at')">`linked_at`,</if>
            <if test="_parameter.containsKey('last_login_at')">`last_login_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('user_id')">#{user_id},</if>
            <if test="_parameter.containsKey('provider')">#{provider},</if>
            <if test="_parameter.containsKey('provider_user_id')">#{provider_user_id},</if>
            <if test="_parameter.containsKey('provider_email')">#{provider_email},</if>
            <if test="_parameter.containsKey('provider_nickname')">#{provider_nickname},</if>
            <if test="_parameter.containsKey('provider_avatar_url')">#{provider_avatar_url},</if>
            <if test="_parameter.containsKey('linked_at')">#{linked_at},</if>
            <if test="_parameter.containsKey('last_login_at')">#{last_login_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_auth`.`linked_accounts`
        <set>
            <if test="_parameter.containsKey('user_id')">`user_id` = #{user_id},</if>
            <if test="_parameter.containsKey('provider')">`provider` = #{provider},</if>
            <if test="_parameter.containsKey('provider_user_id')">`provider_user_id` = #{provider_user_id},</if>
            <if test="_parameter.containsKey('provider_email')">`provider_email` = #{provider_email},</if>
            <if test="_parameter.containsKey('provider_nickname')">`provider_nickname` = #{provider_nickname},</if>
            <if test="_parameter.containsKey('provider_avatar_url')">`provider_avatar_url` = #{provider_avatar_url},</if>
            <if test="_parameter.containsKey('linked_at')">`linked_at` = #{linked_at},</if>
            <if test="_parameter.containsKey('last_login_at')">`last_login_at` = #{last_login_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_auth`.`linked_accounts`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_auth`.`linked_accounts`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
