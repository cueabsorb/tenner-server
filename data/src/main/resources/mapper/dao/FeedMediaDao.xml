<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.FeedMediaDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_social`.`feed_media`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('post_id')">`post_id`,</if>
            <if test="_parameter.containsKey('media_url')">`media_url`,</if>
            <if test="_parameter.containsKey('media_type')">`media_type`,</if>
            <if test="_parameter.containsKey('display_order')">`display_order`,</if>
            <if test="_parameter.containsKey('thumbnail_url')">`thumbnail_url`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('post_id')">#{post_id},</if>
            <if test="_parameter.containsKey('media_url')">#{media_url},</if>
            <if test="_parameter.containsKey('media_type')">#{media_type},</if>
            <if test="_parameter.containsKey('display_order')">#{display_order},</if>
            <if test="_parameter.containsKey('thumbnail_url')">#{thumbnail_url},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_social`.`feed_media`
        <set>
            <if test="_parameter.containsKey('post_id')">`post_id` = #{post_id},</if>
            <if test="_parameter.containsKey('media_url')">`media_url` = #{media_url},</if>
            <if test="_parameter.containsKey('media_type')">`media_type` = #{media_type},</if>
            <if test="_parameter.containsKey('display_order')">`display_order` = #{display_order},</if>
            <if test="_parameter.containsKey('thumbnail_url')">`thumbnail_url` = #{thumbnail_url},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_social`.`feed_media`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_social`.`feed_media`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
