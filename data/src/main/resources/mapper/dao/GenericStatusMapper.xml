<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.mapper.GenericStatusMapper">

    <insert id="insert">
        INSERT INTO `${tableName}`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <foreach collection="entries" item="entry" separator=",">
                `${entry.column}`
            </foreach>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <foreach collection="entries" item="entry" separator=",">
                #{entry.value}
            </foreach>
        </trim>
    </insert>

    <update id="updateById">
        UPDATE `${tableName}`
        <set>
            <foreach collection="entries" item="entry" separator=",">
                `${entry.column}` = #{entry.value}
            </foreach>
        </set>
        WHERE `${idColumn}` = #{id}
    </update>

    <update id="deleteById">
        UPDATE `${tableName}`
        SET `status` = -1
        WHERE `${idColumn}` = #{id}
    </update>

    <select id="findById" resultType="map">
        SELECT *
        FROM `${tableName}`
        WHERE `${idColumn}` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

    <select id="findByColumn" resultType="map">
        SELECT *
        FROM `${tableName}`
        WHERE `${column}` = #{value}
          AND `status` = 0
    </select>

</mapper>
