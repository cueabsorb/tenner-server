<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.LoginAuditLogDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_auth`.`login_audit_log`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('user_id')">`user_id`,</if>
            <if test="_parameter.containsKey('provider')">`provider`,</if>
            <if test="_parameter.containsKey('ip_address')">`ip_address`,</if>
            <if test="_parameter.containsKey('device_info')">`device_info`,</if>
            <if test="_parameter.containsKey('success')">`success`,</if>
            <if test="_parameter.containsKey('created_at')">`created_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('user_id')">#{user_id},</if>
            <if test="_parameter.containsKey('provider')">#{provider},</if>
            <if test="_parameter.containsKey('ip_address')">#{ip_address},</if>
            <if test="_parameter.containsKey('device_info')">#{device_info},</if>
            <if test="_parameter.containsKey('success')">#{success},</if>
            <if test="_parameter.containsKey('created_at')">#{created_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_auth`.`login_audit_log`
        <set>
            <if test="_parameter.containsKey('user_id')">`user_id` = #{user_id},</if>
            <if test="_parameter.containsKey('provider')">`provider` = #{provider},</if>
            <if test="_parameter.containsKey('ip_address')">`ip_address` = #{ip_address},</if>
            <if test="_parameter.containsKey('device_info')">`device_info` = #{device_info},</if>
            <if test="_parameter.containsKey('success')">`success` = #{success},</if>
            <if test="_parameter.containsKey('created_at')">`created_at` = #{created_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_auth`.`login_audit_log`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_auth`.`login_audit_log`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
