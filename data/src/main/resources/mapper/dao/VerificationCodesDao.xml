<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.VerificationCodesDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_auth`.`verification_codes`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('target')">`target`,</if>
            <if test="_parameter.containsKey('code_hash')">`code_hash`,</if>
            <if test="_parameter.containsKey('purpose')">`purpose`,</if>
            <if test="_parameter.containsKey('expires_at')">`expires_at`,</if>
            <if test="_parameter.containsKey('used_at')">`used_at`,</if>
            <if test="_parameter.containsKey('created_at')">`created_at`,</if>
            <if test="_parameter.containsKey('ip_address')">`ip_address`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('target')">#{target},</if>
            <if test="_parameter.containsKey('code_hash')">#{code_hash},</if>
            <if test="_parameter.containsKey('purpose')">#{purpose},</if>
            <if test="_parameter.containsKey('expires_at')">#{expires_at},</if>
            <if test="_parameter.containsKey('used_at')">#{used_at},</if>
            <if test="_parameter.containsKey('created_at')">#{created_at},</if>
            <if test="_parameter.containsKey('ip_address')">#{ip_address},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_auth`.`verification_codes`
        <set>
            <if test="_parameter.containsKey('target')">`target` = #{target},</if>
            <if test="_parameter.containsKey('code_hash')">`code_hash` = #{code_hash},</if>
            <if test="_parameter.containsKey('purpose')">`purpose` = #{purpose},</if>
            <if test="_parameter.containsKey('expires_at')">`expires_at` = #{expires_at},</if>
            <if test="_parameter.containsKey('used_at')">`used_at` = #{used_at},</if>
            <if test="_parameter.containsKey('created_at')">`created_at` = #{created_at},</if>
            <if test="_parameter.containsKey('ip_address')">`ip_address` = #{ip_address},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_auth`.`verification_codes`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_auth`.`verification_codes`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
