<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.FeedPostsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_social`.`feed_posts`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('author_id')">`author_id`,</if>
            <if test="_parameter.containsKey('text')">`text`,</if>
            <if test="_parameter.containsKey('image_urls')">`image_urls`,</if>
            <if test="_parameter.containsKey('play_session_id')">`play_session_id`,</if>
            <if test="_parameter.containsKey('court_id')">`court_id`,</if>
            <if test="_parameter.containsKey('topic_tags')">`topic_tags`,</if>
            <if test="_parameter.containsKey('visibility')">`visibility`,</if>
            <if test="_parameter.containsKey('like_count')">`like_count`,</if>
            <if test="_parameter.containsKey('comment_count')">`comment_count`,</if>
            <if test="_parameter.containsKey('created_at')">`created_at`,</if>
            <if test="_parameter.containsKey('updated_at')">`updated_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('author_id')">#{author_id},</if>
            <if test="_parameter.containsKey('text')">#{text},</if>
            <if test="_parameter.containsKey('image_urls')">#{image_urls},</if>
            <if test="_parameter.containsKey('play_session_id')">#{play_session_id},</if>
            <if test="_parameter.containsKey('court_id')">#{court_id},</if>
            <if test="_parameter.containsKey('topic_tags')">#{topic_tags},</if>
            <if test="_parameter.containsKey('visibility')">#{visibility},</if>
            <if test="_parameter.containsKey('like_count')">#{like_count},</if>
            <if test="_parameter.containsKey('comment_count')">#{comment_count},</if>
            <if test="_parameter.containsKey('created_at')">#{created_at},</if>
            <if test="_parameter.containsKey('updated_at')">#{updated_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_social`.`feed_posts`
        <set>
            <if test="_parameter.containsKey('author_id')">`author_id` = #{author_id},</if>
            <if test="_parameter.containsKey('text')">`text` = #{text},</if>
            <if test="_parameter.containsKey('image_urls')">`image_urls` = #{image_urls},</if>
            <if test="_parameter.containsKey('play_session_id')">`play_session_id` = #{play_session_id},</if>
            <if test="_parameter.containsKey('court_id')">`court_id` = #{court_id},</if>
            <if test="_parameter.containsKey('topic_tags')">`topic_tags` = #{topic_tags},</if>
            <if test="_parameter.containsKey('visibility')">`visibility` = #{visibility},</if>
            <if test="_parameter.containsKey('like_count')">`like_count` = #{like_count},</if>
            <if test="_parameter.containsKey('comment_count')">`comment_count` = #{comment_count},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
            <if test="_parameter.containsKey('created_at')">`created_at` = #{created_at},</if>
            <if test="_parameter.containsKey('updated_at')">`updated_at` = #{updated_at},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_social`.`feed_posts`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_social`.`feed_posts`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
