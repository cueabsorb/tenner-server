<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.PlayParticipantsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_activity`.`play_participants`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('session_id')">`session_id`,</if>
            <if test="_parameter.containsKey('user_id')">`user_id`,</if>
            <if test="_parameter.containsKey('display_name')">`display_name`,</if>
            <if test="_parameter.containsKey('role')">`role`,</if>
            <if test="_parameter.containsKey('side')">`side`,</if>
            <if test="_parameter.containsKey('ntrp_snapshot')">`ntrp_snapshot`,</if>
            <if test="_parameter.containsKey('participant_status')">`participant_status`,</if>
            <if test="_parameter.containsKey('confirmed_at')">`confirmed_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('session_id')">#{session_id},</if>
            <if test="_parameter.containsKey('user_id')">#{user_id},</if>
            <if test="_parameter.containsKey('display_name')">#{display_name},</if>
            <if test="_parameter.containsKey('role')">#{role},</if>
            <if test="_parameter.containsKey('side')">#{side},</if>
            <if test="_parameter.containsKey('ntrp_snapshot')">#{ntrp_snapshot},</if>
            <if test="_parameter.containsKey('participant_status')">#{participant_status},</if>
            <if test="_parameter.containsKey('confirmed_at')">#{confirmed_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_activity`.`play_participants`
        <set>
            <if test="_parameter.containsKey('session_id')">`session_id` = #{session_id},</if>
            <if test="_parameter.containsKey('user_id')">`user_id` = #{user_id},</if>
            <if test="_parameter.containsKey('display_name')">`display_name` = #{display_name},</if>
            <if test="_parameter.containsKey('role')">`role` = #{role},</if>
            <if test="_parameter.containsKey('side')">`side` = #{side},</if>
            <if test="_parameter.containsKey('ntrp_snapshot')">`ntrp_snapshot` = #{ntrp_snapshot},</if>
            <if test="_parameter.containsKey('participant_status')">`participant_status` = #{participant_status},</if>
            <if test="_parameter.containsKey('confirmed_at')">`confirmed_at` = #{confirmed_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_activity`.`play_participants`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_activity`.`play_participants`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
