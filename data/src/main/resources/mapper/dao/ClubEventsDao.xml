            <if test="_parameter.containsKey('club_id')">`club_id`,</if>
            <if test="_parameter.containsKey('organizer_id')">`organizer_id`,</if>
            <if test="_parameter.containsKey('title')">`title`,</if>
            <if test="_parameter.containsKey('court_id')">`court_id`,</if>
            <if test="_parameter.containsKey('court_name')">`court_name`,</if>
            <if test="_parameter.containsKey('started_at')">`started_at`,</if>
            <if test="_parameter.containsKey('ended_at')">`ended_at`,</if>
            <if test="_parameter.containsKey('max_participants')">`max_participants`,</if>
            <if test="_parameter.containsKey('event_status')">`event_status`,</if>
            <if test="_parameter.containsKey('created_at')">`created_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('club_id')">#{club_id},</if>
            <if test="_parameter.containsKey('organizer_id')">#{organizer_id},</if>
            <if test="_parameter.containsKey('title')">#{title},</if>
            <if test="_parameter.containsKey('court_id')">#{court_id},</if>
            <if test="_parameter.containsKey('court_name')">#{court_name},</if>
            <if test="_parameter.containsKey('started_at')">#{started_at},</if>
            <if test="_parameter.containsKey('ended_at')">#{ended_at},</if>
            <if test="_parameter.containsKey('max_participants')">#{max_participants},</if>
            <if test="_parameter.containsKey('event_status')">#{event_status},</if>
            <if test="_parameter.containsKey('created_at')">#{created_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_club`.`club_events`
        <set>
            <if test="_parameter.containsKey('club_id')">`club_id` = #{club_id},</if>
            <if test="_parameter.containsKey('organizer_id')">`organizer_id` = #{organizer_id},</if>
            <if test="_parameter.containsKey('title')">`title` = #{title},</if>
            <if test="_parameter.containsKey('court_id')">`court_id` = #{court_id},</if>
            <if test="_parameter.containsKey('court_name')">`court_name` = #{court_name},</if>
            <if test="_parameter.containsKey('started_at')">`started_at` = #{started_at},</if>
            <if test="_parameter.containsKey('ended_at')">`ended_at` = #{ended_at},</if>
            <if test="_parameter.containsKey('max_participants')">`max_participants` = #{max_participants},</if>
            <if test="_parameter.containsKey('event_status')">`event_status` = #{event_status},</if>
            <if test="_parameter.containsKey('created_at')">`created_at` = #{created_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_club`.`club_events`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_club`.`club_events`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

