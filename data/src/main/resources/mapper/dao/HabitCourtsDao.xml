<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.HabitCourtsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_profile`.`habit_courts`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('habit_id')">`habit_id`,</if>
            <if test="_parameter.containsKey('court_id')">`court_id`,</if>
            <if test="_parameter.containsKey('is_primary')">`is_primary`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('habit_id')">#{habit_id},</if>
            <if test="_parameter.containsKey('court_id')">#{court_id},</if>
            <if test="_parameter.containsKey('is_primary')">#{is_primary},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_profile`.`habit_courts`
        <set>
            <if test="_parameter.containsKey('habit_id')">`habit_id` = #{habit_id},</if>
            <if test="_parameter.containsKey('court_id')">`court_id` = #{court_id},</if>
            <if test="_parameter.containsKey('is_primary')">`is_primary` = #{is_primary},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_profile`.`habit_courts`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_profile`.`habit_courts`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
