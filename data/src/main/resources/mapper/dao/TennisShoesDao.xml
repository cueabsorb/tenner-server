<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.TennisShoesDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_profile`.`tennis_shoes`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('bag_id')">`bag_id`,</if>
            <if test="_parameter.containsKey('brand')">`brand`,</if>
            <if test="_parameter.containsKey('model')">`model`,</if>
            <if test="_parameter.containsKey('size')">`size`,</if>
            <if test="_parameter.containsKey('court_type')">`court_type`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('bag_id')">#{bag_id},</if>
            <if test="_parameter.containsKey('brand')">#{brand},</if>
            <if test="_parameter.containsKey('model')">#{model},</if>
            <if test="_parameter.containsKey('size')">#{size},</if>
            <if test="_parameter.containsKey('court_type')">#{court_type},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_profile`.`tennis_shoes`
        <set>
            <if test="_parameter.containsKey('bag_id')">`bag_id` = #{bag_id},</if>
            <if test="_parameter.containsKey('brand')">`brand` = #{brand},</if>
            <if test="_parameter.containsKey('model')">`model` = #{model},</if>
            <if test="_parameter.containsKey('size')">`size` = #{size},</if>
            <if test="_parameter.containsKey('court_type')">`court_type` = #{court_type},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_profile`.`tennis_shoes`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_profile`.`tennis_shoes`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
