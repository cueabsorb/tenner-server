<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.UserReportsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_privacy`.`user_reports`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('reporter_id')">`reporter_id`,</if>
            <if test="_parameter.containsKey('reported_user_id')">`reported_user_id`,</if>
            <if test="_parameter.containsKey('report_type')">`report_type`,</if>
            <if test="_parameter.containsKey('description')">`description`,</if>
            <if test="_parameter.containsKey('resource_type')">`resource_type`,</if>
            <if test="_parameter.containsKey('resource_id')">`resource_id`,</if>
            <if test="_parameter.containsKey('review_status')">`review_status`,</if>
            <if test="_parameter.containsKey('reviewed_by')">`reviewed_by`,</if>
            <if test="_parameter.containsKey('reviewed_at')">`reviewed_at`,</if>
            <if test="_parameter.containsKey('created_at')">`created_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('reporter_id')">#{reporter_id},</if>
            <if test="_parameter.containsKey('reported_user_id')">#{reported_user_id},</if>
            <if test="_parameter.containsKey('report_type')">#{report_type},</if>
            <if test="_parameter.containsKey('description')">#{description},</if>
            <if test="_parameter.containsKey('resource_type')">#{resource_type},</if>
            <if test="_parameter.containsKey('resource_id')">#{resource_id},</if>
            <if test="_parameter.containsKey('review_status')">#{review_status},</if>
            <if test="_parameter.containsKey('reviewed_by')">#{reviewed_by},</if>
            <if test="_parameter.containsKey('reviewed_at')">#{reviewed_at},</if>
            <if test="_parameter.containsKey('created_at')">#{created_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_privacy`.`user_reports`
        <set>
            <if test="_parameter.containsKey('reporter_id')">`reporter_id` = #{reporter_id},</if>
            <if test="_parameter.containsKey('reported_user_id')">`reported_user_id` = #{reported_user_id},</if>
            <if test="_parameter.containsKey('report_type')">`report_type` = #{report_type},</if>
            <if test="_parameter.containsKey('description')">`description` = #{description},</if>
            <if test="_parameter.containsKey('resource_type')">`resource_type` = #{resource_type},</if>
            <if test="_parameter.containsKey('resource_id')">`resource_id` = #{resource_id},</if>
            <if test="_parameter.containsKey('review_status')">`review_status` = #{review_status},</if>
            <if test="_parameter.containsKey('reviewed_by')">`reviewed_by` = #{reviewed_by},</if>
            <if test="_parameter.containsKey('reviewed_at')">`reviewed_at` = #{reviewed_at},</if>
            <if test="_parameter.containsKey('created_at')">`created_at` = #{created_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_privacy`.`user_reports`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_privacy`.`user_reports`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
