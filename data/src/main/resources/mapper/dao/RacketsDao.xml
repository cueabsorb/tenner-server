<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.RacketsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_profile`.`rackets`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('bag_id')">`bag_id`,</if>
            <if test="_parameter.containsKey('brand')">`brand`,</if>
            <if test="_parameter.containsKey('model')">`model`,</if>
            <if test="_parameter.containsKey('grip_size')">`grip_size`,</if>
            <if test="_parameter.containsKey('weight_gram')">`weight_gram`,</if>
            <if test="_parameter.containsKey('head_size_sq_in')">`head_size_sq_in`,</if>
            <if test="_parameter.containsKey('image_url')">`image_url`,</if>
            <if test="_parameter.containsKey('is_primary')">`is_primary`,</if>
            <if test="_parameter.containsKey('display_order')">`display_order`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('bag_id')">#{bag_id},</if>
            <if test="_parameter.containsKey('brand')">#{brand},</if>
            <if test="_parameter.containsKey('model')">#{model},</if>
            <if test="_parameter.containsKey('grip_size')">#{grip_size},</if>
            <if test="_parameter.containsKey('weight_gram')">#{weight_gram},</if>
            <if test="_parameter.containsKey('head_size_sq_in')">#{head_size_sq_in},</if>
            <if test="_parameter.containsKey('image_url')">#{image_url},</if>
            <if test="_parameter.containsKey('is_primary')">#{is_primary},</if>
            <if test="_parameter.containsKey('display_order')">#{display_order},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_profile`.`rackets`
        <set>
            <if test="_parameter.containsKey('bag_id')">`bag_id` = #{bag_id},</if>
            <if test="_parameter.containsKey('brand')">`brand` = #{brand},</if>
            <if test="_parameter.containsKey('model')">`model` = #{model},</if>
            <if test="_parameter.containsKey('grip_size')">`grip_size` = #{grip_size},</if>
            <if test="_parameter.containsKey('weight_gram')">`weight_gram` = #{weight_gram},</if>
            <if test="_parameter.containsKey('head_size_sq_in')">`head_size_sq_in` = #{head_size_sq_in},</if>
            <if test="_parameter.containsKey('image_url')">`image_url` = #{image_url},</if>
            <if test="_parameter.containsKey('is_primary')">`is_primary` = #{is_primary},</if>
            <if test="_parameter.containsKey('display_order')">`display_order` = #{display_order},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_profile`.`rackets`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_profile`.`rackets`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
