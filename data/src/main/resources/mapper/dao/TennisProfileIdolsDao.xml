<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.TennisProfileIdolsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_profile`.`tennis_profile_idols`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('profile_id')">`profile_id`,</if>
            <if test="_parameter.containsKey('tennis_star_id')">`tennis_star_id`,</if>
            <if test="_parameter.containsKey('custom_name')">`custom_name`,</if>
            <if test="_parameter.containsKey('display_order')">`display_order`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('profile_id')">#{profile_id},</if>
            <if test="_parameter.containsKey('tennis_star_id')">#{tennis_star_id},</if>
            <if test="_parameter.containsKey('custom_name')">#{custom_name},</if>
            <if test="_parameter.containsKey('display_order')">#{display_order},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_profile`.`tennis_profile_idols`
        <set>
            <if test="_parameter.containsKey('profile_id')">`profile_id` = #{profile_id},</if>
            <if test="_parameter.containsKey('tennis_star_id')">`tennis_star_id` = #{tennis_star_id},</if>
            <if test="_parameter.containsKey('custom_name')">`custom_name` = #{custom_name},</if>
            <if test="_parameter.containsKey('display_order')">`display_order` = #{display_order},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_profile`.`tennis_profile_idols`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_profile`.`tennis_profile_idols`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
