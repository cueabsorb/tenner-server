<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.ClubsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_club`.`clubs`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('name')">`name`,</if>
            <if test="_parameter.containsKey('english_name')">`english_name`,</if>
            <if test="_parameter.containsKey('city_code')">`city_code`,</if>
            <if test="_parameter.containsKey('description')">`description`,</if>
            <if test="_parameter.containsKey('cover_image_url')">`cover_image_url`,</if>
            <if test="_parameter.containsKey('owner_id')">`owner_id`,</if>
            <if test="_parameter.containsKey('join_policy')">`join_policy`,</if>
            <if test="_parameter.containsKey('member_count')">`member_count`,</if>
            <if test="_parameter.containsKey('club_status')">`club_status`,</if>
            <if test="_parameter.containsKey('created_at')">`created_at`,</if>
            <if test="_parameter.containsKey('updated_at')">`updated_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('name')">#{name},</if>
            <if test="_parameter.containsKey('english_name')">#{english_name},</if>
            <if test="_parameter.containsKey('city_code')">#{city_code},</if>
            <if test="_parameter.containsKey('description')">#{description},</if>
            <if test="_parameter.containsKey('cover_image_url')">#{cover_image_url},</if>
            <if test="_parameter.containsKey('owner_id')">#{owner_id},</if>
            <if test="_parameter.containsKey('join_policy')">#{join_policy},</if>
            <if test="_parameter.containsKey('member_count')">#{member_count},</if>
            <if test="_parameter.containsKey('club_status')">#{club_status},</if>
            <if test="_parameter.containsKey('created_at')">#{created_at},</if>
            <if test="_parameter.containsKey('updated_at')">#{updated_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_club`.`clubs`
        <set>
            <if test="_parameter.containsKey('name')">`name` = #{name},</if>
            <if test="_parameter.containsKey('english_name')">`english_name` = #{english_name},</if>
            <if test="_parameter.containsKey('city_code')">`city_code` = #{city_code},</if>
            <if test="_parameter.containsKey('description')">`description` = #{description},</if>
            <if test="_parameter.containsKey('cover_image_url')">`cover_image_url` = #{cover_image_url},</if>
            <if test="_parameter.containsKey('owner_id')">`owner_id` = #{owner_id},</if>
            <if test="_parameter.containsKey('join_policy')">`join_policy` = #{join_policy},</if>
            <if test="_parameter.containsKey('member_count')">`member_count` = #{member_count},</if>
            <if test="_parameter.containsKey('club_status')">`club_status` = #{club_status},</if>
            <if test="_parameter.containsKey('created_at')">`created_at` = #{created_at},</if>
            <if test="_parameter.containsKey('updated_at')">`updated_at` = #{updated_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_club`.`clubs`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_club`.`clubs`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
