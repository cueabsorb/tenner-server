<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.AccountDeletionRequestsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_privacy`.`account_deletion_requests`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('user_id')">`user_id`,</if>
            <if test="_parameter.containsKey('reason')">`reason`,</if>
            <if test="_parameter.containsKey('request_status')">`request_status`,</if>
            <if test="_parameter.containsKey('created_at')">`created_at`,</if>
            <if test="_parameter.containsKey('processed_at')">`processed_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('user_id')">#{user_id},</if>
            <if test="_parameter.containsKey('reason')">#{reason},</if>
            <if test="_parameter.containsKey('request_status')">#{request_status},</if>
            <if test="_parameter.containsKey('created_at')">#{created_at},</if>
            <if test="_parameter.containsKey('processed_at')">#{processed_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_privacy`.`account_deletion_requests`
        <set>
            <if test="_parameter.containsKey('user_id')">`user_id` = #{user_id},</if>
            <if test="_parameter.containsKey('reason')">`reason` = #{reason},</if>
            <if test="_parameter.containsKey('request_status')">`request_status` = #{request_status},</if>
            <if test="_parameter.containsKey('created_at')">`created_at` = #{created_at},</if>
            <if test="_parameter.containsKey('processed_at')">`processed_at` = #{processed_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_privacy`.`account_deletion_requests`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_privacy`.`account_deletion_requests`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
