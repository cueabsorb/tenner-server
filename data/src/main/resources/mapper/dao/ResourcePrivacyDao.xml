<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.ResourcePrivacyDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_privacy`.`resource_privacy`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('owner_id')">`owner_id`,</if>
            <if test="_parameter.containsKey('resource_type')">`resource_type`,</if>
            <if test="_parameter.containsKey('resource_id')">`resource_id`,</if>
            <if test="_parameter.containsKey('visibility')">`visibility`,</if>
            <if test="_parameter.containsKey('allowed_club_ids')">`allowed_club_ids`,</if>
            <if test="_parameter.containsKey('allowed_user_ids')">`allowed_user_ids`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('owner_id')">#{owner_id},</if>
            <if test="_parameter.containsKey('resource_type')">#{resource_type},</if>
            <if test="_parameter.containsKey('resource_id')">#{resource_id},</if>
            <if test="_parameter.containsKey('visibility')">#{visibility},</if>
            <if test="_parameter.containsKey('allowed_club_ids')">#{allowed_club_ids},</if>
            <if test="_parameter.containsKey('allowed_user_ids')">#{allowed_user_ids},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_privacy`.`resource_privacy`
        <set>
            <if test="_parameter.containsKey('owner_id')">`owner_id` = #{owner_id},</if>
            <if test="_parameter.containsKey('resource_type')">`resource_type` = #{resource_type},</if>
            <if test="_parameter.containsKey('resource_id')">`resource_id` = #{resource_id},</if>
            <if test="_parameter.containsKey('visibility')">`visibility` = #{visibility},</if>
            <if test="_parameter.containsKey('allowed_club_ids')">`allowed_club_ids` = #{allowed_club_ids},</if>
            <if test="_parameter.containsKey('allowed_user_ids')">`allowed_user_ids` = #{allowed_user_ids},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_privacy`.`resource_privacy`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_privacy`.`resource_privacy`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
