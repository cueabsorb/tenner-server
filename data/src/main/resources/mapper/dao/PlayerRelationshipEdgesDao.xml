<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.PlayerRelationshipEdgesDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_activity`.`player_relationship_edges`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('user_id')">`user_id`,</if>
            <if test="_parameter.containsKey('peer_user_id')">`peer_user_id`,</if>
            <if test="_parameter.containsKey('total_sessions')">`total_sessions`,</if>
            <if test="_parameter.containsKey('last_played_at')">`last_played_at`,</if>
            <if test="_parameter.containsKey('most_common_session_type')">`most_common_session_type`,</if>
            <if test="_parameter.containsKey('relationship_strength')">`relationship_strength`,</if>
            <if test="_parameter.containsKey('updated_at')">`updated_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('user_id')">#{user_id},</if>
            <if test="_parameter.containsKey('peer_user_id')">#{peer_user_id},</if>
            <if test="_parameter.containsKey('total_sessions')">#{total_sessions},</if>
            <if test="_parameter.containsKey('last_played_at')">#{last_played_at},</if>
            <if test="_parameter.containsKey('most_common_session_type')">#{most_common_session_type},</if>
            <if test="_parameter.containsKey('relationship_strength')">#{relationship_strength},</if>
            <if test="_parameter.containsKey('updated_at')">#{updated_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_activity`.`player_relationship_edges`
        <set>
            <if test="_parameter.containsKey('user_id')">`user_id` = #{user_id},</if>
            <if test="_parameter.containsKey('peer_user_id')">`peer_user_id` = #{peer_user_id},</if>
            <if test="_parameter.containsKey('total_sessions')">`total_sessions` = #{total_sessions},</if>
            <if test="_parameter.containsKey('last_played_at')">`last_played_at` = #{last_played_at},</if>
            <if test="_parameter.containsKey('most_common_session_type')">`most_common_session_type` = #{most_common_session_type},</if>
            <if test="_parameter.containsKey('relationship_strength')">`relationship_strength` = #{relationship_strength},</if>
            <if test="_parameter.containsKey('updated_at')">`updated_at` = #{updated_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_activity`.`player_relationship_edges`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_activity`.`player_relationship_edges`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
