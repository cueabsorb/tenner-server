<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.TennisStringSetupsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_profile`.`tennis_string_setups`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('racket_id')">`racket_id`,</if>
            <if test="_parameter.containsKey('main_string_brand')">`main_string_brand`,</if>
            <if test="_parameter.containsKey('cross_string_brand')">`cross_string_brand`,</if>
            <if test="_parameter.containsKey('string_type')">`string_type`,</if>
            <if test="_parameter.containsKey('main_tension_lbs')">`main_tension_lbs`,</if>
            <if test="_parameter.containsKey('cross_tension_lbs')">`cross_tension_lbs`,</if>
            <if test="_parameter.containsKey('strung_at')">`strung_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('racket_id')">#{racket_id},</if>
            <if test="_parameter.containsKey('main_string_brand')">#{main_string_brand},</if>
            <if test="_parameter.containsKey('cross_string_brand')">#{cross_string_brand},</if>
            <if test="_parameter.containsKey('string_type')">#{string_type},</if>
            <if test="_parameter.containsKey('main_tension_lbs')">#{main_tension_lbs},</if>
            <if test="_parameter.containsKey('cross_tension_lbs')">#{cross_tension_lbs},</if>
            <if test="_parameter.containsKey('strung_at')">#{strung_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_profile`.`tennis_string_setups`
        <set>
            <if test="_parameter.containsKey('racket_id')">`racket_id` = #{racket_id},</if>
            <if test="_parameter.containsKey('main_string_brand')">`main_string_brand` = #{main_string_brand},</if>
            <if test="_parameter.containsKey('cross_string_brand')">`cross_string_brand` = #{cross_string_brand},</if>
            <if test="_parameter.containsKey('string_type')">`string_type` = #{string_type},</if>
            <if test="_parameter.containsKey('main_tension_lbs')">`main_tension_lbs` = #{main_tension_lbs},</if>
            <if test="_parameter.containsKey('cross_tension_lbs')">`cross_tension_lbs` = #{cross_tension_lbs},</if>
            <if test="_parameter.containsKey('strung_at')">`strung_at` = #{strung_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_profile`.`tennis_string_setups`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_profile`.`tennis_string_setups`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
