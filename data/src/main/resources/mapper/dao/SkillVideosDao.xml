<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.SkillVideosDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_profile`.`skill_videos`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('certification_id')">`certification_id`,</if>
            <if test="_parameter.containsKey('video_url')">`video_url`,</if>
            <if test="_parameter.containsKey('thumbnail_url')">`thumbnail_url`,</if>
            <if test="_parameter.containsKey('duration_seconds')">`duration_seconds`,</if>
            <if test="_parameter.containsKey('file_size_mb')">`file_size_mb`,</if>
            <if test="_parameter.containsKey('created_at')">`created_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('certification_id')">#{certification_id},</if>
            <if test="_parameter.containsKey('video_url')">#{video_url},</if>
            <if test="_parameter.containsKey('thumbnail_url')">#{thumbnail_url},</if>
            <if test="_parameter.containsKey('duration_seconds')">#{duration_seconds},</if>
            <if test="_parameter.containsKey('file_size_mb')">#{file_size_mb},</if>
            <if test="_parameter.containsKey('created_at')">#{created_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_profile`.`skill_videos`
        <set>
            <if test="_parameter.containsKey('certification_id')">`certification_id` = #{certification_id},</if>
            <if test="_parameter.containsKey('video_url')">`video_url` = #{video_url},</if>
            <if test="_parameter.containsKey('thumbnail_url')">`thumbnail_url` = #{thumbnail_url},</if>
            <if test="_parameter.containsKey('duration_seconds')">`duration_seconds` = #{duration_seconds},</if>
            <if test="_parameter.containsKey('file_size_mb')">`file_size_mb` = #{file_size_mb},</if>
            <if test="_parameter.containsKey('created_at')">`created_at` = #{created_at},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_profile`.`skill_videos`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_profile`.`skill_videos`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
