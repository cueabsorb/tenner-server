<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.HabitWeeklySlotsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_profile`.`habit_weekly_slots`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('habit_id')">`habit_id`,</if>
            <if test="_parameter.containsKey('day_of_week')">`day_of_week`,</if>
            <if test="_parameter.containsKey('start_time')">`start_time`,</if>
            <if test="_parameter.containsKey('end_time')">`end_time`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('habit_id')">#{habit_id},</if>
            <if test="_parameter.containsKey('day_of_week')">#{day_of_week},</if>
            <if test="_parameter.containsKey('start_time')">#{start_time},</if>
            <if test="_parameter.containsKey('end_time')">#{end_time},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_profile`.`habit_weekly_slots`
        <set>
            <if test="_parameter.containsKey('habit_id')">`habit_id` = #{habit_id},</if>
            <if test="_parameter.containsKey('day_of_week')">`day_of_week` = #{day_of_week},</if>
            <if test="_parameter.containsKey('start_time')">`start_time` = #{start_time},</if>
            <if test="_parameter.containsKey('end_time')">`end_time` = #{end_time},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_profile`.`habit_weekly_slots`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_profile`.`habit_weekly_slots`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
