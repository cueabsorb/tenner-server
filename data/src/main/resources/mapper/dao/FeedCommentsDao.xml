<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.irallyin.server.data.dao.FeedCommentsDao">

    <insert id="insert" parameterType="map">
        INSERT INTO `ir_social`.`feed_comments`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">`id`,</if>
            <if test="_parameter.containsKey('post_id')">`post_id`,</if>
            <if test="_parameter.containsKey('author_id')">`author_id`,</if>
            <if test="_parameter.containsKey('content')">`content`,</if>
            <if test="_parameter.containsKey('parent_comment_id')">`parent_comment_id`,</if>
            <if test="_parameter.containsKey('created_at')">`created_at`,</if>
            `status`
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="_parameter.containsKey('id')">#{id},</if>
            <if test="_parameter.containsKey('post_id')">#{post_id},</if>
            <if test="_parameter.containsKey('author_id')">#{author_id},</if>
            <if test="_parameter.containsKey('content')">#{content},</if>
            <if test="_parameter.containsKey('parent_comment_id')">#{parent_comment_id},</if>
            <if test="_parameter.containsKey('created_at')">#{created_at},</if>
            0
        </trim>
    </insert>

    <update id="updateById" parameterType="map">
        UPDATE `ir_social`.`feed_comments`
        <set>
            <if test="_parameter.containsKey('post_id')">`post_id` = #{post_id},</if>
            <if test="_parameter.containsKey('author_id')">`author_id` = #{author_id},</if>
            <if test="_parameter.containsKey('content')">`content` = #{content},</if>
            <if test="_parameter.containsKey('parent_comment_id')">`parent_comment_id` = #{parent_comment_id},</if>
            <if test="_parameter.containsKey('status')">`status` = #{status},</if>
            <if test="_parameter.containsKey('created_at')">`created_at` = #{created_at},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <update id="deleteById" parameterType="map">
        UPDATE `ir_social`.`feed_comments`
        SET `status` = -1
        WHERE `id` = #{id}
    </update>

    <select id="findById" parameterType="map" resultType="map">
        SELECT *
        FROM `ir_social`.`feed_comments`
        WHERE `id` = #{id}
          AND `status` = 0
        LIMIT 1
    </select>

</mapper>
